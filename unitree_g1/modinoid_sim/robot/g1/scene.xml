<mujoco model="g1_29dof scene">
  <!-- <include file="g1_29dof.xml"/> -->
  <!-- <include file="g1_29dof_with_hand.xml"/> -->
  <include file="g1_29dof_3d.xml"/>
  <!-- <include file="g1_test.xml"/> -->

  <statistic center="0 0 0.5" extent="2.0"/>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="-130" elevation="-20"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3"
      markrgb="0.8 0.8 0.8" width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5" reflectance="0.2"/>
    
    <!-- Table material -->
    <material name="table_wood" rgba="0.6 0.4 0.2 1"/>
    
    <!-- Apple material (red) -->
    <material name="apple_red" rgba="0.8 0.1 0.1 1"/>
  </asset>

  <worldbody>
    <light pos="0 0 1.5" dir="0 0 -1" directional="true"/>
    <geom name="floor" size="0 0 0.05" type="plane" material="groundplane"/>
    
    <!-- Table in front of robot (smaller) -->
    <body name="table" pos="0.5 0 0">
      <!-- Table top -->
      <geom name="table_top" type="box" size="0.3 0.25 0.02" pos="0 0 0.65" material="table_wood"/>
      
      <!-- Table legs -->
      <geom name="table_leg_1" type="cylinder" size="0.025 0.325" pos="0.24 0.18 0.325" material="table_wood"/>
      <geom name="table_leg_2" type="cylinder" size="0.025 0.325" pos="0.24 -0.18 0.325" material="table_wood"/>
      <geom name="table_leg_3" type="cylinder" size="0.025 0.325" pos="-0.24 0.18 0.325" material="table_wood"/>
      <geom name="table_leg_4" type="cylinder" size="0.025 0.325" pos="-0.24 -0.18 0.325" material="table_wood"/>
    </body>
    
    <!-- Apple on table (closer to robot/edge) -->
    <body name="apple" pos="0.5 0 0.72">
      <freejoint/>
      <geom name="apple_body" type="sphere" size="0.04" material="apple_red" mass="0.2"/>
      <!-- Apple stem -->
      <geom name="apple_stem" type="cylinder" size="0.005 0.02" pos="0 0 0.045" rgba="0.4 0.3 0.1 1"/>
    </body>
  </worldbody>
</mujoco>
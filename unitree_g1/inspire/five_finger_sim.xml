    <texture type="2d" name="doorframe_tex" builtin="flat"    rgb1="0.30 0.18 0.08" width="128" height="128" />
    <texture type="2d" name="table_tex"     builtin="flat"    rgb1="0.60 0.40 0.20" width="512" height="512" />
    <texture type="2d" name="cube_tex"      builtin="flat"    rgb1="0.18 0.68 0.72" width="512" height="512" />


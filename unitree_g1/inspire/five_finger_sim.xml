<mujoco model="g1_29dof_inspire sim scene">
  <include file="r_robot.xml"/>

  <!-- implicitfast keeps the joint damping stable; plain Euler does not.
       elliptic cones: single conic friction constraint per contact (needed for the
       contact-rich house scene: jug + glass + water particles + grasping). -->
  <option integrator="implicitfast" cone="elliptic"/>

  <!-- Collision-filter classes for the jug/glass/water world.
       bit 0 = robot/world, bit 1 = water world.
       container sees both; water_particle sees container only. -->
  <default>
    <geom friction="1.0"/>
    <default class="container">
      <geom contype="3" conaffinity="3"/>
    </default>
    <default class="water_particle">
      <geom contype="2" conaffinity="0"/>
    </default>
  </default>

  <statistic center="3.2 2.0 1.0" extent="8.0"/>
  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="120" elevation="-20" offwidth="1280" offheight="1280"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3"
      markrgb="0.8 0.8 0.8" width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5" reflectance="0.2"/>

    <!-- ── House structure textures ────────────────────────────── -->
    <texture type="2d" name="wall_tex"      builtin="flat"    rgb1="0.90 0.86 0.78" width="512" height="512" />

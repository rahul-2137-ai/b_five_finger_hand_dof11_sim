<mujoco model="g1_29dof_inspire sim scene">
  <include file="g1_29dof_inspire_fb.xml"/>

  <!-- implicitfast keeps the joint damping stable; plain Euler does not -->
  <option integrator="implicitfast"/>

  <statistic center="0 0 0.5" extent="2.0"/>
  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="120" elevation="-20" offwidth="1280" offheight="1280"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3"
      markrgb="0.8 0.8 0.8" width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5" reflectance="0.2"/>
  </asset>

  <worldbody>
    <light pos="0 0 1.5" dir="0 0 -1" directional="true"/>
    <geom name="floor" size="0 0 0.05" type="plane" material="groundplane"/>
  </worldbody>

  <!-- Finger mimic couplings (URDF <mimic>) re-added as equality constraints. -->
  <equality>
    <joint joint1="L_thumb_intermediate_joint" joint2="L_thumb_proximal_pitch_joint" polycoef="0 1.6 0 0 0" solref="0.004 1" solimp="0.99 0.999 0.001"/>
    <joint joint1="L_thumb_distal_joint" joint2="L_thumb_proximal_pitch_joint" polycoef="0 2.4 0 0 0" solref="0.004 1" solimp="0.99 0.999 0.001"/>
    <joint joint1="L_index_intermediate_joint" joint2="L_index_proximal_joint" polycoef="0 1.0 0 0 0" solref="0.004 1" solimp="0.99 0.999 0.001"/>
    <joint joint1="L_middle_intermediate_joint" joint2="L_middle_proximal_joint" polycoef="0 1.0 0 0 0" solref="0.004 1" solimp="0.99 0.999 0.001"/>
    <joint joint1="L_ring_intermediate_joint" joint2="L_ring_proximal_joint" polycoef="0 1.0 0 0 0" solref="0.004 1" solimp="0.99 0.999 0.001"/>
    <joint joint1="L_pinky_intermediate_joint" joint2="L_pinky_proximal_joint" polycoef="0 1.0 0 0 0" solref="0.004 1" solimp="0.99 0.999 0.001"/>
    <joint joint1="R_thumb_intermediate_joint" joint2="R_thumb_proximal_pitch_joint" polycoef="0 1.6 0 0 0" solref="0.004 1" solimp="0.99 0.999 0.001"/>
    <joint joint1="R_thumb_distal_joint" joint2="R_thumb_proximal_pitch_joint" polycoef="0 2.4 0 0 0" solref="0.004 1" solimp="0.99 0.999 0.001"/>
    <joint joint1="R_index_intermediate_joint" joint2="R_index_proximal_joint" polycoef="0 1.0 0 0 0" solref="0.004 1" solimp="0.99 0.999 0.001"/>
    <joint joint1="R_middle_intermediate_joint" joint2="R_middle_proximal_joint" polycoef="0 1.0 0 0 0" solref="0.004 1" solimp="0.99 0.999 0.001"/>
    <joint joint1="R_ring_intermediate_joint" joint2="R_ring_proximal_joint" polycoef="0 1.0 0 0 0" solref="0.004 1" solimp="0.99 0.999 0.001"/>
    <joint joint1="R_pinky_intermediate_joint" joint2="R_pinky_proximal_joint" polycoef="0 1.0 0 0 0" solref="0.004 1" solimp="0.99 0.999 0.001"/>
  </equality>

  <actuator>
    <!-- ── 29 body motors: direct-drive torque (driven by WBC PD via rt/lowcmd) ── -->
    <motor name="left_hip_pitch_joint" joint="left_hip_pitch_joint" ctrlrange="-88 88"/>
    <motor name="left_hip_roll_joint" joint="left_hip_roll_joint" ctrlrange="-139 139"/>
    <motor name="left_hip_yaw_joint" joint="left_hip_yaw_joint" ctrlrange="-88 88"/>
    <motor name="left_knee_joint" joint="left_knee_joint" ctrlrange="-139 139"/>
    <motor name="left_ankle_pitch_joint" joint="left_ankle_pitch_joint" ctrlrange="-35 35"/>
    <motor name="left_ankle_roll_joint" joint="left_ankle_roll_joint" ctrlrange="-35 35"/>
    <motor name="right_hip_pitch_joint" joint="right_hip_pitch_joint" ctrlrange="-88 88"/>
    <motor name="right_hip_roll_joint" joint="right_hip_roll_joint" ctrlrange="-139 139"/>
    <motor name="right_hip_yaw_joint" joint="right_hip_yaw_joint" ctrlrange="-88 88"/>
    <motor name="right_knee_joint" joint="right_knee_joint" ctrlrange="-139 139"/>
    <motor name="right_ankle_pitch_joint" joint="right_ankle_pitch_joint" ctrlrange="-35 35"/>
    <motor name="right_ankle_roll_joint" joint="right_ankle_roll_joint" ctrlrange="-35 35"/>
    <motor name="waist_yaw_joint" joint="waist_yaw_joint" ctrlrange="-88 88"/>
    <motor name="waist_roll_joint" joint="waist_roll_joint" ctrlrange="-35 35"/>
    <motor name="waist_pitch_joint" joint="waist_pitch_joint" ctrlrange="-35 35"/>
    <motor name="left_shoulder_pitch_joint" joint="left_shoulder_pitch_joint" ctrlrange="-25 25"/>
    <motor name="left_shoulder_roll_joint" joint="left_shoulder_roll_joint" ctrlrange="-25 25"/>
    <motor name="left_shoulder_yaw_joint" joint="left_shoulder_yaw_joint" ctrlrange="-25 25"/>
    <motor name="left_elbow_joint" joint="left_elbow_joint" ctrlrange="-25 25"/>
    <motor name="left_wrist_roll_joint" joint="left_wrist_roll_joint" ctrlrange="-25 25"/>
    <motor name="left_wrist_pitch_joint" joint="left_wrist_pitch_joint" ctrlrange="-5 5"/>
    <motor name="left_wrist_yaw_joint" joint="left_wrist_yaw_joint" ctrlrange="-5 5"/>
    <motor name="right_shoulder_pitch_joint" joint="right_shoulder_pitch_joint" ctrlrange="-25 25"/>
    <motor name="right_shoulder_roll_joint" joint="right_shoulder_roll_joint" ctrlrange="-25 25"/>
    <motor name="right_shoulder_yaw_joint" joint="right_shoulder_yaw_joint" ctrlrange="-25 25"/>
    <motor name="right_elbow_joint" joint="right_elbow_joint" ctrlrange="-25 25"/>
    <motor name="right_wrist_roll_joint" joint="right_wrist_roll_joint" ctrlrange="-25 25"/>
    <motor name="right_wrist_pitch_joint" joint="right_wrist_pitch_joint" ctrlrange="-5 5"/>
    <motor name="right_wrist_yaw_joint" joint="right_wrist_yaw_joint" ctrlrange="-5 5"/>

    <!-- ── 12 Inspire finger motors: position servos (driven by rt/inspire/cmd) ──
         thumb drives two coupled joints, so it gets a stiffer gain. -->
    <position name="L_thumb_proximal_yaw_joint" joint="L_thumb_proximal_yaw_joint" kp="80" kv="1.0" ctrlrange="-0.1000 1.3000" forcerange="-60 60"/>
    <position name="L_thumb_proximal_pitch_joint" joint="L_thumb_proximal_pitch_joint" kp="80" kv="1.0" ctrlrange="-0.1000 0.6000" forcerange="-60 60"/>
    <position name="L_index_proximal_joint" joint="L_index_proximal_joint" kp="18" kv="1.0" ctrlrange="0.0000 1.7000" forcerange="-60 60"/>
    <position name="L_middle_proximal_joint" joint="L_middle_proximal_joint" kp="18" kv="1.0" ctrlrange="0.0000 1.7000" forcerange="-60 60"/>
    <position name="L_ring_proximal_joint" joint="L_ring_proximal_joint" kp="18" kv="1.0" ctrlrange="0.0000 1.7000" forcerange="-60 60"/>
    <position name="L_pinky_proximal_joint" joint="L_pinky_proximal_joint" kp="18" kv="1.0" ctrlrange="0.0000 1.7000" forcerange="-60 60"/>
    <position name="R_thumb_proximal_yaw_joint" joint="R_thumb_proximal_yaw_joint" kp="80" kv="1.0" ctrlrange="-0.1000 1.3000" forcerange="-60 60"/>
    <position name="R_thumb_proximal_pitch_joint" joint="R_thumb_proximal_pitch_joint" kp="80" kv="1.0" ctrlrange="-0.1000 0.6000" forcerange="-60 60"/>
    <position name="R_index_proximal_joint" joint="R_index_proximal_joint" kp="18" kv="1.0" ctrlrange="0.0000 1.7000" forcerange="-60 60"/>
    <position name="R_middle_proximal_joint" joint="R_middle_proximal_joint" kp="18" kv="1.0" ctrlrange="0.0000 1.7000" forcerange="-60 60"/>
    <position name="R_ring_proximal_joint" joint="R_ring_proximal_joint" kp="18" kv="1.0" ctrlrange="0.0000 1.7000" forcerange="-60 60"/>
    <position name="R_pinky_proximal_joint" joint="R_pinky_proximal_joint" kp="18" kv="1.0" ctrlrange="0.0000 1.7000" forcerange="-60 60"/>
  </actuator>
</mujoco>
